# Server-only. Never prefix this variable with NEXT_PUBLIC_.
UPRIVER_API_KEY=

# Fixture is the safe default and never calls Upriver.
UPRIVER_MODE=fixture

# Required in addition to UPRIVER_MODE=live before the controlled workflow can
# construct a paid gateway for an exact public YouTube handle or channel URL.
# Live peer discovery uses Upriver Similar Beta and has no fuzzy fallback.
# Browser requests cannot set either flag.
UPRIVER_LIVE_WORKFLOW=false

# Enables only the separate six-credit contract test. It never enables the
# live workflow. Ordinary CI leaves this false.
UPRIVER_LIVE_SMOKE=false

# Server-only persistence, per-run credit, and cache policy. Every new run
# receives an independent ledger capped at 160 credits, reserved up front and
# preflighted before each tool call; there is no lifetime shutdown. Similar
# Beta is provisionally priced at one creator-result credit per returned result
# until Upriver confirms its billing contract.
SPONSOR_RADAR_DATA_DIR=.data/sponsor-radar
SPONSOR_RADAR_RUN_CREDIT_LIMIT=160
# Max age of cached evidence (target/peer/sponsor/verification). Anything older
# is treated as expired and re-fetched from the provider, so a run never serves
# a stale result that could hide an upstream outage. Default 1 hour.
SPONSOR_RADAR_CACHE_TTL_MS=3600000

# Required in production. Railway serves the app over HTTPS; share these
# credentials only with reviewers. Local development stays open when omitted.
SPONSOR_RADAR_BASIC_AUTH_USER=
SPONSOR_RADAR_BASIC_AUTH_PASSWORD=

# Server-only planner mode for the autonomous engine, which requires a
# planner LLM: disabled is rejected and fails run creation. fixture is the
# deterministic, network-free scripted planner and is only valid with
# UPRIVER_MODE=fixture; openai works with fixture or live evidence (live also
# needs UPRIVER_LIVE_WORKFLOW=true). Browser requests cannot change this mode.
SPONSOR_RADAR_LLM_MODE=fixture

# Paid OpenAI execution requires all three server-only settings. The adapter
# is a zero-retry, tool-calling Responses planner: serial tool calls only,
# pinned model, no stored responses. Per-run ceilings are enforced in code:
# 12 planner calls, 20,000 output tokens, and 160 credits.
SPONSOR_RADAR_LIVE_LLM=false
OPENAI_API_KEY=
SPONSOR_RADAR_OPENAI_MODEL=gpt-5.6-terra

# Planner turn ceiling per run; enforced in code, never by the model.
SPONSOR_RADAR_AGENT_MAX_ITERATIONS=12
# Enables only the separate paid end-to-end agentic smoke (test:live-agentic).
SPONSOR_RADAR_AGENTIC_LIVE_SMOKE=false
# Channel the agentic live smoke researches; defaults to @Dave2D.
SPONSOR_RADAR_AGENTIC_SMOKE_CHANNEL=
